# Prisma (Supabase Postgres)
# Pooled connection for runtime queries (required).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for `prisma migrate` / `prisma db push` (no pooler).
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
# Local shadow database for `prisma migrate dev`. Supabase does not allow
# Prisma to create a shadow DB on the hosted instance, so the local Docker
# Postgres from docker-compose.yml is used instead. Required only when
# generating new migrations; not used at runtime.
SHADOW_DATABASE_URL="postgresql://codelearn:codelearn@localhost:5434/codelearn_shadow?schema=public"

# Supabase (publishable key, safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Supabase secret key (server-only, never expose to the browser).
# Bypasses RLS — use only from trusted server code.
SUPABASE_SECRET_KEY=""
